{
  "name": "s2cfgtojson",
  "version": "7.0.19",
  "description": "Converts Stalker 2 Cfg file into POJOs",
  "keywords": [
    "stalker",
    "unrealengine",
    "typescript",
    "javascript",
    "modding",
    "mod",
    "utility"
  ],
  "homepage": "https://github.com/sdwvit/s2cfgtojson#readme",
  "bugs": {
    "url": "https://github.com/sdwvit/s2cfgtojson/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sdwvit/s2cfgtojson.git"
  },
  "license": "ISC",
  "author": "sdwvit",
  "type": "module",
  "main": "./dist/Struct.mjs",
  "types": "./dist/Struct.d.mts",
  "exports": {
    ".": {
      "types": "./dist/Struct.d.mts",
      "import": "./dist/Struct.mjs",
      "default": "./dist/Struct.mjs"
    },
    "./Struct": {
      "types": "./dist/Struct.d.mts",
      "import": "./dist/Struct.mjs"
    },
    "./types": {
      "types": "./dist/types.d.mts",
      "import": "./dist/types.mjs"
    },
    "./enums": {
      "types": "./dist/enums.d.mts",
      "import": "./dist/enums.mjs"
    },
    "./utility-types": {
      "types": "./dist/utility-types.d.mts",
      "import": "./dist/utility-types.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "readme.md",
    "skills/public"
  ],
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "release:patch": "npm version patch && npm i && npm audit fix && npm run build && npm login && npm publish"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=24"
  }
}
